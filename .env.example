# Mux Data Environment Key for Player Monitoring
# Get this from Mux Dashboard (Settings > Environments)
VITE_MUX_ENV_KEY=your_mux_env_key_here

# Mux API Access Token (Required for fetching asset list automatically)
# Create a token in the Mux Dashboard (Settings > Access Tokens)
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here
